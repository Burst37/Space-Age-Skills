# ─── VPS / SSH ──────────────────────────────────────────────────────────────
VPS_HOST=146.190.78.120
VPS_USER=root
# Path to your SSH private key (no passphrase, or use SSH agent)
VPS_KEY_PATH=~/.ssh/id_rsa
# Optional: override default SSH port
VPS_PORT=22

# ─── AI APIs (OpenAI SDK-compatible) ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-proj-...
MINIMAX_API_KEY=sk-api-...

# ─── Agent CLI paths (auto-detected via `which` if omitted) ──────────────────
# AGENTIC_OS_CLAUDE_BIN=/usr/local/bin/claude
# AGENTIC_OS_HERMES_BIN=/usr/local/bin/hermes
# AGENTIC_OS_GEMINI_BIN=/usr/local/bin/gemini
# AGENTIC_OS_CODEX_BIN=/usr/local/bin/codex

# ─── Obsidian vault ──────────────────────────────────────────────────────────
AGENTIC_OS_VAULT=/path/to/your/obsidian/vault
# Space Age vault name (for obsidian CLI commands)
OBSIDIAN_VAULT_NAME=Space Age

# ─── App config ──────────────────────────────────────────────────────────────
# Location shown in top bar
AGENTIC_OS_LOCATION=Dallas
# Default Codex/OpenClaw agent
AGENTIC_OS_OPENCLAW_AGENT=main
