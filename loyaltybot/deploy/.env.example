# LoyaltyBot environment — copy to loyaltybot/.env and fill in.
# NEVER commit the real .env (it is git-ignored). Values here are placeholders.

# CapSolver API key. Used only if config.json has no "capsolver_api_key".
CAPSOLVER_API_KEY=

# Browser backend: "chromium" (default) or "camoufox" (stealth Firefox).
# camoufox requires: pip install camoufox[geoip] && python -m camoufox fetch
LB_BROWSER=chromium

# Default run tuning (these are convenience defaults for run.sh; CLI flags win).
LB_WORKERS=4
LB_HEADLESS=true
LB_CAPTCHA_TIMEOUT=120
