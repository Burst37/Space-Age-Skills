# Private Nightclub — environment
# Copy to .env.local for local dev. All values are optional; forms and the
# concierge fall back to safe local behavior when these are unset.

# Where form submissions are forwarded (e.g. a Make/Zapier webhook, n8n, or
# a serverless email endpoint). If unset, submissions are logged server-side
# and still return success to the client.
RESERVATIONS_WEBHOOK_URL=
GUESTLIST_WEBHOOK_URL=

# Optional: power the AI concierge with a live model. If unset, the concierge
# answers from the built-in venue knowledge base (no key required).
CONCIERGE_API_KEY=
CONCIERGE_MODEL=claude-opus-4-8

# Public venue contact shown in the UI (safe to expose).
NEXT_PUBLIC_VENUE_PHONE=+1 (314) 555-0142
NEXT_PUBLIC_VENUE_EMAIL=vip@privatestl.com
